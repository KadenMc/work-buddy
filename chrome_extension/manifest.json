{
  "manifest_version": 3,
  "name": "Work Buddy Tab Exporter",
  "version": "1.2.0",
  "description": "Exports tab metadata, browsing history, session data, and on-demand page content to a local native messaging host. Read-only.",
  "permissions": [
    "tabs",
    "nativeMessaging",
    "alarms",
    "tabGroups",
    "history",
    "sessions",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
